CHUTES_API_KEY=
CHUTES_OAUTH_CLIENT_ID=
CHUTES_OAUTH_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=
CHUTES_OAUTH_REDIRECT_URI=

# The TEE-enabled model used for all 6 agents (inference runs on llm.chutes.ai)
CHUTES_MODEL=deepseek-ai/DeepSeek-V3.2-TEE

# The chute ID for TEE attestation evidence (api.chutes.ai/chutes/{id}/evidence).
# Leave blank to fall back to the model name.
CHUTES_CHUTE_ID=
